---
import Layout from '../layouts/Layout.astro';
---

<Layout title="書籍一覧">
  <section aria-labelledby="book-list-heading">
    <div class="toolbar">
      <h1 id="book-list-heading">Library <span class="accent">Collection</span></h1>
      <a href="/new" class="btn btn-primary">+ 新規登録</a>
    </div>

    <nav aria-label="ステータスフィルター" style="margin-top:1rem;">
      <div class="filter-group">
        <button class="filter-btn active" data-status="all">すべて</button>
        <button class="filter-btn" data-status="UNREAD">未読</button>
        <button class="filter-btn" data-status="READING">読書中</button>
        <button class="filter-btn" data-status="COMPLETED">読了</button>
      </div>
    </nav>

    <div id="book-grid" class="book-grid" role="list" aria-label="書籍リスト">
      <div class="loading"></div>
    </div>
  </section>

  <script>
    const API_BASE = import.meta.env.PUBLIC_API_URL || '';

    const statusLabels: Record<string, string> = {
      UNREAD: '未読',
      READING: '読書中',
      COMPLETED: '読了',
    };

    async function loadBooks(status?: string) {
      const grid = document.getElementById('book-grid')!;
      grid.innerHTML = '<div class="loading"></div>';

      try {
        const url = status && status !== 'all'
          ? `${API_BASE}/api/books/status/${status}`
          : `${API_BASE}/api/books`;
        const res = await fetch(url);
        const books = await res.json();

        if (books.length === 0) {
          grid.innerHTML = `
            <div class="empty-state" style="grid-column: 1 / -1;">
              <p>書籍が登録されていません</p>
              <a href="/new" class="btn btn-primary">最初の一冊を登録する</a>
            </div>`;
          return;
        }

        grid.innerHTML = books.map((book: any, i: number) => `
          <article class="glass-card book-card" role="listitem" style="animation-delay: ${i * 0.06}s">
            <div>
              <span class="badge" data-status="${book.status}">${statusLabels[book.status]}</span>
            </div>
            <h3>${escapeHtml(book.title)}</h3>
            <p class="meta">
              <span>${escapeHtml(book.author)}</span>
              ${book.isbn ? `<span>/ ${escapeHtml(book.isbn)}</span>` : ''}
            </p>
            ${book.memo ? `<p class="memo">${escapeHtml(book.memo)}</p>` : ''}
            <div class="actions">
              <button class="btn btn-ghost btn-sm edit-btn" data-id="${book.id}">編集</button>
              <button class="btn btn-danger btn-sm delete-btn" data-id="${book.id}">削除</button>
            </div>
          </article>
        `).join('');

        // 削除
        grid.querySelectorAll('.delete-btn').forEach(btn => {
          btn.addEventListener('click', async () => {
            const id = (btn as HTMLElement).dataset.id;
            if (confirm('この書籍を削除しますか？')) {
              await fetch(`${API_BASE}/api/books/${id}`, { method: 'DELETE' });
              loadBooks(status);
            }
          });
        });

        // 編集（モーダルの代わりにアラートで簡易実装）
        grid.querySelectorAll('.edit-btn').forEach(btn => {
          btn.addEventListener('click', async () => {
            const id = (btn as HTMLElement).dataset.id;
            const res = await fetch(`${API_BASE}/api/books/${id}`);
            const book = await res.json();
            const newStatus = prompt(
              `「${book.title}」のステータスを変更\n\n1: 未読\n2: 読書中\n3: 読了\n\n現在: ${statusLabels[book.status]}`,
              book.status === 'UNREAD' ? '1' : book.status === 'READING' ? '2' : '3'
            );
            if (newStatus) {
              const statusMap: Record<string, string> = { '1': 'UNREAD', '2': 'READING', '3': 'COMPLETED' };
              book.status = statusMap[newStatus] || book.status;
              await fetch(`${API_BASE}/api/books/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(book),
              });
              loadBooks(status);
            }
          });
        });
      } catch {
        grid.innerHTML = `
          <div class="empty-state" style="grid-column: 1 / -1;">
            <p>データの取得に失敗しました。<br/>バックエンドが起動しているか確認してください。</p>
          </div>`;
      }
    }

    function escapeHtml(str: string): string {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    // フィルター
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        loadBooks((btn as HTMLElement).dataset.status);
      });
    });

    loadBooks();
  </script>
</Layout>
<!-- test -->
